-- SPREAD MODIFICATIONS
-- ============================================================================
local SpreadConfig = getgenv().Mooze["Weapon Modifications"]
    and getgenv().Mooze["Weapon Modifications"]["Spread Modifications"]

local function ApplySpread()
    if not SpreadConfig or not SpreadConfig.Enabled then return end
    local function NormalizeString(text) return tostring(text):lower():gsub("%W", "") end
    for weaponKey, settings in pairs(SpreadConfig) do
        if weaponKey ~= "Enabled" and type(settings) == "table" then
            local multiplier = settings.Multiplier
            local hSpread = 0.1 * multiplier
            local vSpread = 0.1 * multiplier
            local keyName = NormalizeString(weaponKey)
            for _, fn in ipairs(getgc(true)) do
                if type(fn) == "function" and islclosure(fn) and not isexecutorclosure(fn) then
                    local info = debug.getinfo(fn)
                    if info and info.short_src then
                        if NormalizeString(info.short_src):find(keyName, 1, true) then
                            for idx, constant in ipairs(debug.getconstants(fn)) do
                                if type(constant) == "number" then
                                    if constant > 0 and constant < 0.1 then
                                        debug.setconstant(fn, idx, hSpread)
                                    elseif constant >= 0.1 and constant < 0.3 then
                                        debug.setconstant(fn, idx, vSpread)
                                    end
                                end
                            end
                        end
                    end
                end
            end
        end
    end
end

ApplySpread()
LocalPlayer.CharacterAdded:Connect(function()
    task.wait(1)
    ApplySpread()
    BodyPartCache = {}
end)

