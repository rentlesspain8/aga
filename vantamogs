local Config         = shared.MoozeV2
local TriggerConfig  = Config["Trigger Bot"]

local TriggerCircle = Drawing.new("Circle")
TriggerCircle.Visible      = false
TriggerCircle.Transparency = 1
TriggerCircle.Color        = Color3.new(1,1,1)
TriggerCircle.Filled       = true
TriggerCircle.Radius       = TriggerConfig["FOV"] * 5
TriggerCircle.NumSides     = 64
TriggerCircle.Position     = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)

local LastTriggerStep   = 0
local TriggerStepInterval = 0.05
local LastActivationTime  = 0

local function GetTargetInFOV()
    local closestDistance = math.huge
    local bestPlayer = nil
    local circlePosition = TriggerCircle.Position
    local radius = TriggerCircle.Radius
    local prediction = TriggerConfig.Prediction
    local velocityEnabled = VelocityConfig.Enabled
    local velocityMagnitude = VelocityConfig.Magnitude

    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            local bodyParts = GetBodyParts(player.Character)
            for _, part in ipairs(bodyParts) do
                if part.Transparency < 1 then
                    local position = part.Position
                    if part.Name == "HumanoidRootPart" then
                        local pred = TriggerConfig["Prediction"]
                        position = position + Vector3.new(pred["X"], pred["Y"], pred["Z"])
                        local velCfg = TriggerConfig["Velocity"]
                        if velCfg and velCfg["Enabled"] then
                            local velocity = part.Velocity
                            if velocity.Magnitude > velCfg["Magnitude"] then
                                position = position + velocity * 0.1
                            end
                        end
                    end
                    local screenPosition, onScreen = Camera:WorldToScreenPoint(position)
                    if onScreen and screenPosition.Z > 0 then
                        local distance = (Vector2.new(screenPosition.X, screenPosition.Y) - circlePosition).Magnitude
                        if distance <= radius and distance < closestDistance then
                            closestDistance = distance
                            bestPlayer = player
                        end
                    end
                end
            end
        end
    end
    return bestPlayer
end

local TriggerKey = Enum.KeyCode[TriggerConfig["Bind"]:upper()]
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if not gameProcessed and input.KeyCode == TriggerKey then
        if TriggerConfig["Type"] == "Toggle" then
            TriggerConfig["Enabled"] = not TriggerConfig["Enabled"]
        end
        ShowNotification("Trigger Bot", TriggerConfig["Enabled"] and "Enabled" or "Disabled", 2)
    end
end)

RunService.Heartbeat:Connect(function(deltaTime)
    LastTriggerStep = LastTriggerStep + deltaTime
    if LastTriggerStep < TriggerStepInterval then return end
    LastTriggerStep = 0

    if TriggerConfig["Enabled"] then
        local target = GetTargetInFOV()
        TriggerCircle.Radius = TriggerConfig["FOV"] * 5
        TriggerCircle.Position = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)

        if target and LocalPlayer.Character then
