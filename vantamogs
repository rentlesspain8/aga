-- SPREAD MODIFICATIONS
-- ============================================================================
local SpreadConfig = shared.MoozeV2["Weapon Modifications"]
    and shared.MoozeV2["Weapon Modifications"]["Spread Changer"]

local function ApplySpread()
    if not SpreadConfig or not SpreadConfig["Enabled"] then return end
    local function Norm(text) return tostring(text):lower():gsub("%W", "") end
    for weaponKey, settings in pairs(SpreadConfig) do
        if weaponKey ~= "Enabled" and type(settings) == "table" then
            local val    = settings["Value"] or 1
            local spread = 0.1 * val
            local keyName = Norm(weaponKey)
            for _, fn in ipairs(getgc(true)) do
                if type(fn) == "function" and islclosure(fn) and not isexecutorclosure(fn) then
                    local info = debug.getinfo(fn)
                    if info and info.short_src and Norm(info.short_src):find(keyName, 1, true) then
                        for idx, constant in ipairs(debug.getconstants(fn)) do
                            if type(constant) == "number" and constant > 0 and constant < 0.3 then
                                debug.setconstant(fn, idx, spread)
                            end
                        end
                    end
                end
            end
        end
    end
end

ApplySpread()
