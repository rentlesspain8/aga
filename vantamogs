-- ============================================================================
do
    local rf=CFG()["Weapon Modifications"]["Rapid Fire"]
    if rf["Enabled"] then
        local props={"Cooldown","FireRate","ShootCooldown","Delay","ShootDelay"}
        RunService.Heartbeat:Connect(function()
            if not CFG()["Weapon Modifications"]["Rapid Fire"]["Enabled"] then return end
            local char=LocalPlayer.Character
            local tool=char and char:FindFirstChildOfClass("Tool")
            if not tool then return end
            local cdv=CFG()["Weapon Modifications"]["Rapid Fire"]["Cooldown"] or 0
            for _,prop in ipairs(props) do
                local v=tool:FindFirstChild(prop)
                if v and (v:IsA("NumberValue") or v:IsA("IntValue")) then v.Value=cdv end
                local gc=tool:FindFirstChild("Configuration") or tool:FindFirstChild("GunConfig")
                if gc then local r=gc:FindFirstChild(prop); if r and (r:IsA("NumberValue") or r:IsA("IntValue")) then r.Value=cdv end end
            end
        end)
        ShowNotification("Rapid Fire","cooldown: "..(rf["Cooldown"] or 0),3)
    end
end

