        if input.KeyCode == Enum.KeyCode.R and not Reloading then
            Reloading = true
            task.delay(1.5, function() Reloading = false end)
        end
    end)

    LocalPlayer.CharacterAdded:Connect(function(character)
        Character = character
        Humanoid  = character:FindFirstChildOfClass("Humanoid") or character:WaitForChild("Humanoid")
        Shooting  = false; Reloading = false
    end)

    RunService.RenderStepped:Connect(function()
        if not SpeedConfig.Enabled then return end
        if not Humanoid or Humanoid.Health <= 0 then return end
        local speed = SpeedConfig.Normal and SpeedConfig.Normal.Multiplier or Humanoid.WalkSpeed
        if Humanoid.Health < LowHealthThreshold and SpeedConfig["Low Health"] then
            speed = SpeedConfig["Low Health"].Multiplier
        elseif Reloading and SpeedConfig.Reloading then
            speed = SpeedConfig.Reloading.Multiplier
        elseif Shooting and SpeedConfig.Shooting then
            speed = SpeedConfig.Shooting.Multiplier
        end
        if Humanoid.WalkSpeed ~= speed then Humanoid.WalkSpeed = speed end
    end)

    ShowNotification("Walkspeed", "Enabled — speed: " .. SpeedConfig.Normal.Multiplier, 4)
else
    print("[Walkspeed] Disabled by config")
end

-- ============================================================================
-- RAPID FIRE
-- ============================================================================
local RapidFireConfig = getgenv().Mooze["Rapid Fire"]

print("[Rapid Fire] Enabled:", RapidFireConfig and RapidFireConfig.Enabled or false)
if RapidFireConfig and RapidFireConfig.Enabled then
    local CooldownProps = {"Cooldown", "FireRate", "ShootCooldown", "Delay", "ShootDelay"}
    RunService.Heartbeat:Connect(function()
        if not RapidFireConfig.Enabled then return end
        local char = LocalPlayer.Character
        local tool = char and char:FindFirstChildOfClass("Tool")
        if not tool then return end
        local cdv = RapidFireConfig.CooldownValue or 0
        for _, prop in ipairs(CooldownProps) do
            local v = tool:FindFirstChild(prop)
            if v and (v:IsA("NumberValue") or v:IsA("IntValue")) then v.Value = cdv end
            local gc = tool:FindFirstChild("Configuration") or tool:FindFirstChild("GunConfig")
            if gc then
                local r = gc:FindFirstChild(prop)
                if r and (r:IsA("NumberValue") or r:IsA("IntValue")) then r.Value = cdv end
            end
        end
    end)
    ShowNotification("Rapid Fire", "Enabled — cooldown set to " .. (RapidFireConfig.CooldownValue or 0), 4)
else
    print("[Rapid Fire] Disabled by config")
end

