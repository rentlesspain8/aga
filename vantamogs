-- CAMERA AIMBOT
-- ============================================================================
do
    local CamCfg       = shared.MoozeV2["Camera Lock"]
    local CurrentCamera = Services.Workspace.CurrentCamera
    local AimKey        = Enum.KeyCode[shared.MoozeV2["General"]["Binds"]["Camera Lock"]:upper()]

    local function IsKnockedOut(character)
        if not character then return false end
        local bodyEffects = character:FindFirstChild("BodyEffects")
        if bodyEffects then
            local ko = bodyEffects:FindFirstChild("K.O")
            if ko and ko.Value then return true end
        end
        local humanoid = character:FindFirstChildOfClass("Humanoid")
        if humanoid then
            local state = humanoid:GetState()
            if state == Enum.HumanoidStateType.Dead or
               state == Enum.HumanoidStateType.Physics or
               state == Enum.HumanoidStateType.Ragdoll then return true end
        end
        local rootPart = character:FindFirstChild("HumanoidRootPart")
        if rootPart and rootPart:FindFirstChild("GRABBING_CONSTRAINT") then return true end
        return false
    end

    local function GetLockTarget()
        if Locked and LockTarget then
            if LockTarget.Parent and LockTarget.Parent:FindFirstChild("Humanoid") then
                local humanoid = LockTarget.Parent:FindFirstChild("Humanoid")
                local character = LockTarget.Parent
                if humanoid and humanoid.Health > 0 and not IsKnockedOut(character) then
                    return LockTarget
                end
            end
            Locked = false; LockTarget = nil
            ShowNotification("Target Lost", "unlocked", 2)
            CamCfg["Enabled"] = false
            return nil
        end
        return nil
    end

    local function FindMouseTarget()
        local bestTarget, shortestDistance = nil, math.huge
        local mousePosition = UserInputService:GetMouseLocation()
        for _, player in ipairs(Players:GetPlayers()) do
            if player ~= LocalPlayer and player.Character and not IsKnockedOut(player.Character) then
                local rootPart = player.Character:FindFirstChild("HumanoidRootPart")
                if rootPart then
                    local sp, on = CurrentCamera:WorldToViewportPoint(rootPart.Position)
                    if on and sp.Z > 0 then
                        local distance = (Vector2.new(sp.X, sp.Y) - mousePosition).Magnitude
                        if distance < shortestDistance then shortestDistance = distance; bestTarget = rootPart end
                    end
                end
            end
        end
        return bestTarget
    end

    UserInputService.InputBegan:Connect(function(input, processed)
        if processed then return end
        if input.KeyCode == AimKey then
            if not Locked then
                local bestTarget = FindMouseTarget()
                if bestTarget then
                    Locked = true; LockTarget = bestTarget
                    local player = Players:GetPlayerFromCharacter(bestTarget.Parent)
                    if player then ShowNotification("Locked", player.Name, 2) end
                    CamCfg["Enabled"] = true
                else
                    ShowNotification("No Target", "no player near mouse", 2)
                end
            else
                Locked = false; LockTarget = nil
                CamCfg["Enabled"] = false
                ShowNotification("Unlocked", "lock off", 2)
            end
        end
    end)

    RunService.RenderStepped:Connect(function()
        if CamCfg["Enabled"] then
            local targetPart = GetLockTarget()
            if targetPart then
                CurrentCamera.CFrame = CFrame.new(CurrentCamera.CFrame.Position, targetPart.Position)
            end
        end
    end)
end

-- ============================================================================
-- SILENT AIMBOT
-- ============================================================================
do
    local SACfg             = shared.MoozeV2["Silent Aim"]
    local LocalPlayer       = Players.LocalPlayer
    local Camera            = Services.Workspace.CurrentCamera
    local Mouse             = LocalPlayer:GetMouse()
    local LastMousePosition = Vector2.new(0, 0)
    local CurrentTarget     = nil
    local SilentAimActive   = SACfg["Enabled"] == true

    -- keybind toggle
    local SAKey = Enum.KeyCode[shared.MoozeV2["General"]["Binds"]["Silent Aim"]:upper()]
    UserInputService.InputBegan:Connect(function(input, gameProcessed)
        if gameProcessed then return end
        if input.KeyCode == SAKey then
            SilentAimActive = not SilentAimActive
            ShowNotification("Silent Aim", SilentAimActive and "Enabled" or "Disabled", 2)
        end
    end)

    local function GetClosestPoint(player)
        local bestPart, bestDistance = nil, math.huge
        local pointScale = SACfg["Closest Point"] and SACfg["Closest Point"]["Scale"] or 1.0
        if player.Character then
            local bodyParts = GetBodyParts(player.Character)
            for _, part in ipairs(bodyParts) do
                local screenPosition, onScreen = Camera:WorldToViewportPoint(part.Position)
                if onScreen and screenPosition.Z > 0 then
                    local pointPosition = Vector2.new(screenPosition.X, screenPosition.Y)
                    local distance = (LastMousePosition - pointPosition).Magnitude * pointScale
                    if distance < bestDistance then
                        bestPart, bestDistance = part, distance
                    end
                end
            end
        end
        return bestPart
    end

    local FOVCircle = Drawing.new("Circle")
    FOVCircle.Visible      = SACfg["FOV"]["Enabled"] and SACfg["FOV"]["Visible"]
    FOVCircle.Transparency = 1
    FOVCircle.Thickness    = 1.5
    FOVCircle.Color        = Color3.new(1, 1, 1)
    FOVCircle.NumSides     = 128
    FOVCircle.Filled       = false
    FOVCircle.Radius       = SACfg["FOV"]["Size"] * 5

    local CachedRadius = FOVCircle.Radius

    local function IsShiftLockActive()
        -- check for ADS/aim tool (original check)
        if LocalPlayer.Character then
            local tool = LocalPlayer.Character:FindFirstChildOfClass("Tool")
            if tool and tool:FindFirstChild("Ammo") then
                return true
            end
        end
        local playerGui = LocalPlayer:FindFirstChildOfClass("PlayerGui")
        if playerGui then
            local aimGui = playerGui:FindFirstChild("Aim")
            if aimGui and aimGui.Visible then return true end
        end
        local mouse = LocalPlayer:GetMouse()
        if mouse.Icon == "rbxasset://SystemCursors/Cross" then return true end
        local playerModule = LocalPlayer.PlayerScripts:FindFirstChild("PlayerModule")
        if playerModule then
            local cameraModule = playerModule:FindFirstChild("CameraModule")
            if cameraModule then
                local mouseLockController = cameraModule:FindFirstChild("MouseLockController")
                if mouseLockController then
                    local isMouseLocked = mouseLockController:FindFirstChild("isMouseLocked")
                    if isMouseLocked and isMouseLocked.Value then return true end
                end
            end
        end
        return false
    end

    -- FOV circle position: every render frame, zero throttle = smooth
    RunService.RenderStepped:Connect(function()
        local fovCfg = SACfg["FOV"]
        FOVCircle.Visible = fovCfg["Enabled"] and fovCfg["Visible"]
        if not FOVCircle.Visible then return end

        if IsShiftLockActive() then
            local centerScreen = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
            FOVCircle.Position = centerScreen
            LastMousePosition  = centerScreen
        else
            local mp = UserInputService:GetMouseLocation()
            FOVCircle.Position = mp
            LastMousePosition  = mp
        end
    end)

    -- radius + target finding: throttled
    local LastFOVUpdate    = 0
    local FOVUpdateInterval = 0.033
    RunService.Heartbeat:Connect(function(deltaTime)
        LastFOVUpdate = LastFOVUpdate + deltaTime
        if LastFOVUpdate < FOVUpdateInterval then return end
        LastFOVUpdate = 0

        local fovConfig   = SACfg["FOV"]
        local currentTool = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Tool")
        local radius      = fovConfig["Size"] * 5

        if fovConfig["Weapons"]["Enabled"] and currentTool then
            local weaponName = string.lower(currentTool.Name or "")
            if string.find(weaponName, "shotgun") then
                radius = fovConfig["Weapons"]["Shotguns"] * 5
            elseif string.find(weaponName, "pistol") then
                radius = fovConfig["Weapons"]["Pistols"] * 5
            end
        end

        if radius ~= CachedRadius then
            CachedRadius     = radius
            FOVCircle.Radius = radius
        end

        local bestPart, bestDistance = nil, math.huge
        for _, player in pairs(Players:GetPlayers()) do
            if player ~= LocalPlayer and player.Character then
                local targetPart = nil
                if SACfg["Hit Part"] == "Closest Point" then
                    targetPart = GetClosestPoint(player)
                else
                    targetPart = player.Character:FindFirstChild(SACfg["Hit Part"] or "Head")
                end
                if targetPart then
                    local screenPosition, onScreen = Camera:WorldToViewportPoint(targetPart.Position)
                    if onScreen and screenPosition.Z > 0 then
                        local pointPosition = Vector2.new(screenPosition.X, screenPosition.Y)
                        local distance = (LastMousePosition - pointPosition).Magnitude
                        if distance < bestDistance and distance <= radius then
                            bestPart, bestDistance = targetPart, distance
                        end
                    end
                end
            end
        end
        CurrentTarget = bestPart
    end)

    local function ApplyPrediction(cframe, offset)
        return cframe * CFrame.new(offset.X, offset.Y, offset.Z)
    end

    if Capabilities[5] then
        local success = pcall(function()
            local metatable = getrawmetatable(game)
            setreadonly(metatable, false)
            local oldIndex = metatable.__index
            metatable.__index = newcclosure(function(object, property)
                if object:IsA("Mouse") and (property == "Hit" or property == "Target") then
                    local target = CurrentTarget
                    if target and SilentAimActive then
                        local prediction = SACfg["Prediction"]
                        local redirection = SACfg["Client Redirect"]
                        local currentTool = (LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Tool")) or nil
                        if redirection["Enabled"] and currentTool then
                            local toolName = tostring(currentTool.Name)
                            for _, weapon in ipairs(redirection["Weapons"]) do
                                if string.find(string.lower(toolName), string.lower(weapon)) then
                                    prediction = redirection["Prediction"]
                                    break
                                end
                            end
                        end
                        local predictionMultiplier = Vector3.new(prediction["X"], prediction["Y"], prediction["Z"])
                        local offset = target.Velocity * predictionMultiplier
                        if property == "Hit" then
                            return ApplyPrediction(target.CFrame, offset)
                        else
                            return target
                        end
                    end
                end
                return oldIndex(object, property)
            end)
        end)
        if success then
            print("[Silent Aim] Metatable hooking enabled with shiftlock fix")
        else
            warn("[Silent Aim] Metatable hooking failed, using basic mode")
            ShowNotification("Silent Aim", "basic mode", 4)
        end
    else
        warn("[Silent Aim] Metatable hooking not supported on this executor")
        ShowNotification("Silent Aim", "limited mode (no metatable)", 4)
    end
end

