-- Target finding: throttled
RunService.Heartbeat:Connect(function(dt)
    SALastUpdate=SALastUpdate+dt
    if SALastUpdate<0.033 then return end; SALastUpdate=0
    local saCfg=CFG()["Silent Aim"]
    if not saCfg["Enabled"] then SACurrentTarget=nil; return end

    local fovCfg=saCfg["FOV"]
    local radius=fovCfg["Size"]*5
    if fovCfg["Weapons"]["Enabled"] then
        local tool=LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Tool")
        if tool then
            local wn=string.lower(tool.Name or "")
            if string.find(wn,"shotgun") then radius=fovCfg["Weapons"]["Shotguns"]*5
            elseif string.find(wn,"pistol") then radius=fovCfg["Weapons"]["Pistols"]*5 end
        end
    end
    SACircle.Radius=radius

    -- if we have a locked target, only aim at them
    if SATarget then
        if PlayerDead(SATarget) or PlayerKnocked(SATarget) then
            SATarget=nil; SAActive=false
            ShowNotification("Silent Aim","target lost",2); SACurrentTarget=nil; return
        end
        local hp=saCfg["Hit Part"]
        local part = hp=="Closest Point" and SAGetClosestPoint(SATarget)
            or SATarget.Character and SATarget.Character:FindFirstChild(hp or "Head")
        SACurrentTarget=part; return
    end

    SACurrentTarget=nil
end)

-- Keybind: press to lock nearest in FOV, press again to unlock
UserInputService.InputBegan:Connect(function(input,gp)
    if gp then return end
    if not CFG()["Silent Aim"]["Enabled"] then return end  -- master switch
    local bind=CFG()["General"]["Binds"]["Silent Aim"]:upper()
    if input.KeyCode~=Enum.KeyCode[bind] then return end
    if SATarget then
        SATarget=nil; SAActive=false
        ShowNotification("Silent Aim","untargeted",2)
    else
        local best,bd=nil,math.huge
        local mp=UserInputService:GetMouseLocation()
        local radius=CFG()["Silent Aim"]["FOV"]["Size"]*5
        for _,p in ipairs(Players:GetPlayers()) do
            if p~=LocalPlayer and p.Character and not PlayerDead(p) and not PlayerKnocked(p) then
                local hrp=p.Character:FindFirstChild("HumanoidRootPart")
                if hrp then
                    local sp,on=Camera:WorldToViewportPoint(hrp.Position)
                    if on and sp.Z>0 then
                        local d=(Vector2.new(sp.X,sp.Y)-mp).Magnitude
                        if d<=radius and d<bd then bd=d; best=p end
                    end
                end
            end
        end
        if best then
            SATarget=best; SAActive=true
            ShowNotification("Silent Aim","targeting "..best.Name,2)
        else
            ShowNotification("Silent Aim","no target in FOV",2)
        end
    end
end)

-- Metatable hook
if Capabilities[5] then
    local ok=pcall(function()
        local mt=getrawmetatable(game)
        setreadonly(mt,false)
        local oldIdx=mt.__index
        mt.__index=newcclosure(function(obj,key)
            if obj:IsA("Mouse") and (key=="Hit" or key=="Target") then
                local saCfg=CFG()["Silent Aim"]
                local target=SACurrentTarget
                if target and SAActive and saCfg["Enabled"] then
                    local pred=saCfg["Prediction"]
                    local redir=saCfg["Client Redirect"]
                    local tool=LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Tool")
                    if redir["Enabled"] and tool then
                        for _,w in ipairs(redir["Weapons"]) do
                            if string.find(string.lower(tostring(tool.Name)),string.lower(w)) then
                                pred=redir["Prediction"]; break
                            end
                        end
                    end
                    local offset=target.Velocity*Vector3.new(pred["X"],pred["Y"],pred["Z"])
                    local cf=target.CFrame*CFrame.new(offset.X,offset.Y,offset.Z)
                    if key=="Hit" then return cf else return target end
                end
            end
            return oldIdx(obj,key)
        end)
    end)
    if ok then print("[Silent Aim] Metatable hook enabled")
    else warn("[Silent Aim] Metatable hook failed"); ShowNotification("Silent Aim","basic mode",4) end
else
    warn("[Silent Aim] Not supported"); ShowNotification("Silent Aim","limited mode",4)
end

