-- RAPID FIRE
-- ============================================================================
local RapidFireConfig = shared.MoozeV2["Weapon Modifications"]["Rapid Fire"]

print("[Rapid Fire] Enabled:", RapidFireConfig and RapidFireConfig["Enabled"] or false)
if RapidFireConfig and RapidFireConfig["Enabled"] then
    local CooldownProps = {"Cooldown", "FireRate", "ShootCooldown", "Delay", "ShootDelay"}
    RunService.Heartbeat:Connect(function()
        if not RapidFireConfig["Enabled"] then return end
        local char = LocalPlayer.Character
        local tool = char and char:FindFirstChildOfClass("Tool")
        if not tool then return end
        local cdv = RapidFireConfig["Cooldown"] or 0
        for _, prop in ipairs(CooldownProps) do
            local v = tool:FindFirstChild(prop)
            if v and (v:IsA("NumberValue") or v:IsA("IntValue")) then v.Value = cdv end
            local gc = tool:FindFirstChild("Configuration") or tool:FindFirstChild("GunConfig")
            if gc then
                local r = gc:FindFirstChild(prop)
                if r and (r:IsA("NumberValue") or r:IsA("IntValue")) then r.Value = cdv end
            end
        end
    end)
    ShowNotification("Rapid Fire", "cooldown → " .. (RapidFireConfig["Cooldown"] or 0), 3)
else
    print("[Rapid Fire] Disabled by config")
end

