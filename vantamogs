-- Runtime state
local SACurrentTarget = nil  -- BasePart being aimed at
local SALastMousePos  = Vector2.new(0, 0)
local SALastUpdate    = 0
local isMouseDown     = false  -- only redirect during actual shots

-- Track mouse button state
UserInputService.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
