-- Metatable hook
if Capabilities[5] then
    local ok=pcall(function()
        local mt=getrawmetatable(game)
        setreadonly(mt,false)
        local oldIdx=mt.__index
        mt.__index=newcclosure(function(obj,key)
            if obj:IsA("Mouse") and (key=="Hit" or key=="Target") then
                local saCfg=CFG()["Silent Aim"]
                local target=SACurrentTarget
                if target and SAActive and saCfg["Enabled"] then
                    local pred=saCfg["Prediction"]
                    local redir=saCfg["Client Redirect"]
                    local tool=LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Tool")
                    if redir["Enabled"] and tool then
                        for _,w in ipairs(redir["Weapons"]) do
                            if string.find(string.lower(tostring(tool.Name)),string.lower(w)) then
                                pred=redir["Prediction"]; break
                            end
                        end
                    end
                    local offset=target.Velocity*Vector3.new(pred["X"],pred["Y"],pred["Z"])
                    local cf=target.CFrame*CFrame.new(offset.X,offset.Y,offset.Z)
                    if key=="Hit" then return cf else return target end
                end
            end
            return oldIdx(obj,key)
        end)
    end)
    if ok then print("[Silent Aim] Metatable hook enabled")
    else warn("[Silent Aim] Metatable hook failed"); ShowNotification("Silent Aim","basic mode",4) end
else
    warn("[Silent Aim] Not supported"); ShowNotification("Silent Aim","limited mode",4)
end

