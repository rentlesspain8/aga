end)

RunService.Heartbeat:Connect(function(dt)
    TBStep=TBStep+dt
    if TBStep<0.05 then return end; TBStep=0
    local tbCfg=CFG()["Trigger Bot"]
    -- master switch from config
    if not tbCfg["Enabled"] then TBCircle.Visible=false; return end
    if not TBActive then TBCircle.Visible=false; return end
    TBCircle.Radius=tbCfg["FOV"]*5
    TBCircle.Position=Vector2.new(Camera.ViewportSize.X/2,Camera.ViewportSize.Y/2)
    local target=TBGetTarget()
    if target and LocalPlayer.Character then
        local tool=LocalPlayer.Character:FindFirstChildOfClass("Tool")
        if tool and tool:FindFirstChild("Handle") then
            local function clean(s) return s:lower():gsub("[%[%]%- ]","") end
            local tn=clean(tool.Name); local ok=false
            for _,w in ipairs(tbCfg["Weapons"]) do if tn:find(clean(w),1,true) then ok=true; break end end
            if ok and tick()-TBLastShot>=tbCfg["Cooldown"] then
                tool:Activate(); tool:Deactivate(); TBLastShot=tick()
            end
        end
    end
end)

-- ============================================================================
-- CAMERA LOCK  (only runs if shared.MoozeV2["Camera Lock"]["Enabled"] == true)
-- ============================================================================
local function IsKnockedOut(char)
    if not char then return false end
    local be=char:FindFirstChild("BodyEffects")
    if be then local k=be:FindFirstChild("K.O"); if k and k.Value then return true end end
    local hum=char:FindFirstChildOfClass("Humanoid")
    if hum then
        local s=hum:GetState()
        if s==Enum.HumanoidStateType.Dead or s==Enum.HumanoidStateType.Physics or s==Enum.HumanoidStateType.Ragdoll then return true end
    end
    local hrp=char:FindFirstChild("HumanoidRootPart")
    if hrp and hrp:FindFirstChild("GRABBING_CONSTRAINT") then return true end
    return false
end

UserInputService.InputBegan:Connect(function(input,gp)
    if gp then return end
    if not CFG()["Camera Lock"]["Enabled"] then return end  -- master switch
    local bind=CFG()["General"]["Binds"]["Camera Lock"]:upper()
    if input.KeyCode~=Enum.KeyCode[bind] then return end
    if CamLocked then
        CamLocked=false; CamTarget=nil
        ShowNotification("Camera Lock","off",2)
    else
        local best,bd=nil,math.huge
        local mp=UserInputService:GetMouseLocation()
        for _,p in ipairs(Players:GetPlayers()) do
            if p~=LocalPlayer and p.Character and not IsKnockedOut(p.Character) then
                local hrp=p.Character:FindFirstChild("HumanoidRootPart")
                if hrp then
                    local sp,on=Camera:WorldToViewportPoint(hrp.Position)
                    if on and sp.Z>0 then
                        local d=(Vector2.new(sp.X,sp.Y)-mp).Magnitude
                        if d<bd then bd=d; best=hrp end
                    end
                end
            end
        end
        if best then
            CamLocked=true; CamTarget=best
            local pl=Players:GetPlayerFromCharacter(best.Parent)
            ShowNotification("Camera Lock", pl and pl.Name or "locked", 2)
        else
            ShowNotification("Camera Lock","no target near mouse",2)
        end
    end
end)

RunService.RenderStepped:Connect(function()
    if not CFG()["Camera Lock"]["Enabled"] then return end  -- master switch
    if not CamLocked or not CamTarget then return end
    -- validate target still alive
    local char=CamTarget.Parent
    if not char or IsKnockedOut(char) then
        CamLocked=false; CamTarget=nil
        ShowNotification("Camera Lock","target lost",2); return
    end
    Camera.CFrame=CFrame.new(Camera.CFrame.Position,CamTarget.Position)
end)

-- ============================================================================
-- SILENT AIM  (only active if shared.MoozeV2["Silent Aim"]["Enabled"] == true)
-- ============================================================================
local SACurrentTarget = nil  -- the body part being aimed at
local SALastMousePos  = Vector2.new(0,0)
local SALastUpdate    = 0

local SACircle = Drawing.new("Circle")
SACircle.Transparency=1; SACircle.Thickness=1.5; SACircle.Color=Color3.new(1,1,1)
SACircle.NumSides=128; SACircle.Filled=false
SACircle.Radius=CFG()["Silent Aim"]["FOV"]["Size"]*5
SACircle.Visible=CFG()["Silent Aim"]["Enabled"] and CFG()["Silent Aim"]["FOV"]["Enabled"] and CFG()["Silent Aim"]["FOV"]["Visible"]

local function SAIsShiftLock()
    if LocalPlayer.Character then
        local tool=LocalPlayer.Character:FindFirstChildOfClass("Tool")
        if tool and tool:FindFirstChild("Ammo") then return true end
    end
    local pg=LocalPlayer:FindFirstChildOfClass("PlayerGui")
    if pg then local ag=pg:FindFirstChild("Aim"); if ag and ag.Visible then return true end end
    local mouse=LocalPlayer:GetMouse()
    if mouse.Icon=="rbxasset://SystemCursors/Cross" then return true end
    local pm=LocalPlayer.PlayerScripts:FindFirstChild("PlayerModule")
    if pm then
        local cm=pm:FindFirstChild("CameraModule")
        if cm then
            local mlc=cm:FindFirstChild("MouseLockController")
            if mlc then local iml=mlc:FindFirstChild("isMouseLocked"); if iml and iml.Value then return true end end
        end
    end
    return false
end

local function SAGetClosestPoint(player)
    local best,bd=nil,math.huge
    local scale=(CFG()["Silent Aim"]["Closest Point"] or {})["Scale"] or 1.0
    if player.Character then
        for _,part in ipairs(GetBodyParts(player.Character)) do
            local sp,on=Camera:WorldToViewportPoint(part.Position)
            if on and sp.Z>0 then
                local d=(SALastMousePos-Vector2.new(sp.X,sp.Y)).Magnitude*scale
                if d<bd then best=part; bd=d end
            end
        end
    end
    return best
end

-- FOV circle: every render frame, zero throttle
RunService.RenderStepped:Connect(function()
    local saCfg=CFG()["Silent Aim"]
    local fovCfg=saCfg["FOV"]
    SACircle.Visible = saCfg["Enabled"] and fovCfg["Enabled"] and fovCfg["Visible"]
    if not SACircle.Visible then return end
    if SAIsShiftLock() then
        local c=Vector2.new(Camera.ViewportSize.X*0.5,Camera.ViewportSize.Y*0.5)
        SACircle.Position=c; SALastMousePos=c
    else
        local mp=UserInputService:GetMouseLocation()
        SACircle.Position=mp; SALastMousePos=mp
    end
end)

-- Target finding: throttled
RunService.Heartbeat:Connect(function(dt)
    SALastUpdate=SALastUpdate+dt
    if SALastUpdate<0.033 then return end; SALastUpdate=0
    local saCfg=CFG()["Silent Aim"]
    if not saCfg["Enabled"] then SACurrentTarget=nil; return end

    local fovCfg=saCfg["FOV"]
    local radius=fovCfg["Size"]*5
    if fovCfg["Weapons"]["Enabled"] then
        local tool=LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Tool")
        if tool then
            local wn=string.lower(tool.Name or "")
            if string.find(wn,"shotgun") then radius=fovCfg["Weapons"]["Shotguns"]*5
            elseif string.find(wn,"pistol") then radius=fovCfg["Weapons"]["Pistols"]*5 end
        end
    end
    SACircle.Radius=radius

    -- if we have a locked target, only aim at them
    if SATarget then
        if PlayerDead(SATarget) or PlayerKnocked(SATarget) then
            SATarget=nil; SAActive=false
            ShowNotification("Silent Aim","target lost",2); SACurrentTarget=nil; return
        end
        local hp=saCfg["Hit Part"]
        local part = hp=="Closest Point" and SAGetClosestPoint(SATarget)
            or SATarget.Character and SATarget.Character:FindFirstChild(hp or "Head")
        SACurrentTarget=part; return
    end

    SACurrentTarget=nil
end)

