-- TRIGGER BOT
-- ============================================================================
local Config        = getgenv().Mooze
local TriggerConfig = Config["Trigger Bot"]
local VelocityConfig = Config["Velocity Calculation"]

local TriggerCircle = Drawing.new("Circle")
TriggerCircle.Visible   = false
TriggerCircle.Transparency = 1
TriggerCircle.Color     = Color3.new(1,1,1)
TriggerCircle.Filled    = true
TriggerCircle.Radius    = TriggerConfig["FOV"]["X"] * 5
TriggerCircle.NumSides  = math.clamp(math.floor(TriggerCircle.Radius * 2), 20, 100)
TriggerCircle.Position  = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)

local LastTriggerStep   = 0
local TriggerStepInterval = 0.05
local LastActivationTime  = 0

local function GetTargetInFOV()
    local closestDistance = math.huge
    local bestPlayer = nil
    local circlePosition = TriggerCircle.Position
    local radius = TriggerCircle.Radius
    local prediction = TriggerConfig.Prediction
    local velocityEnabled = VelocityConfig.Enabled
    local velocityMagnitude = VelocityConfig.Magnitude

    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            local bodyParts = GetBodyParts(player.Character)
            for _, part in ipairs(bodyParts) do
                if part.Transparency < 1 then
                    local position = part.Position
                    if part.Name == "HumanoidRootPart" then
                        position = position + Vector3.new(prediction.X, prediction.Y, prediction.Z)
                        if velocityEnabled then
                            local velocity = part.Velocity
                            if velocity.Magnitude > velocityMagnitude then
                                position = position + velocity * 0.1
                            end
                        end
                    end
                    local screenPosition, onScreen = Camera:WorldToScreenPoint(position)
                    if onScreen and screenPosition.Z > 0 then
                        local distance = (Vector2.new(screenPosition.X, screenPosition.Y) - circlePosition).Magnitude
                        if distance <= radius and distance < closestDistance then
                            closestDistance = distance
                            bestPlayer = player
                        end
                    end
                end
            end
        end
    end
    return bestPlayer
end

local TriggerKey = Enum.KeyCode[TriggerConfig.Activation["Activation Bind"]:upper()]
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if not gameProcessed and input.KeyCode == TriggerKey then
        TriggerConfig.Enabled = not TriggerConfig.Enabled
        print("[Trigger Bot]", TriggerConfig.Enabled and "Enabled" or "Disabled")
        ShowNotification("Trigger Bot", TriggerConfig.Enabled and "Enabled" or "Disabled", 3)
    end
end)

RunService.Heartbeat:Connect(function(deltaTime)
    LastTriggerStep = LastTriggerStep + deltaTime
    if LastTriggerStep < TriggerStepInterval then return end
    LastTriggerStep = 0

    if TriggerConfig.Enabled then
        local target = GetTargetInFOV()
        local aimGui = LocalPlayer:FindFirstChildOfClass("PlayerGui")
            and LocalPlayer.PlayerGui:FindFirstChild("Aim")
        if aimGui then
            TriggerCircle.Position = aimGui.AbsolutePosition
            TriggerCircle.Radius = TriggerConfig["FOV"]["X"] * 5
            TriggerCircle.NumSides = math.clamp(math.floor(TriggerCircle.Radius * 2), 20, 100)
        end

        if target and LocalPlayer.Character then
            local tool = LocalPlayer.Character:FindFirstChildOfClass("Tool")
            if tool and tool:FindFirstChild("Handle") then
                local cleanName = function(text) return text:lower():gsub("[%[%]%- ]","") end
                local toolName = cleanName(tool.Name)
                local allowed = false
                for _, weapon in ipairs(TriggerConfig.Weapons) do
                    if toolName:find(cleanName(weapon), 1, true) then allowed = true; break end
                end
                if allowed and tick() - LastActivationTime >= TriggerConfig["Click Cooldown"] then
                    tool:Activate(); tool:Deactivate()
                    LastActivationTime = tick()
                end
            end
        end
    end
end)

-- ============================================================================
-- CAMERA AIMBOT
-- ============================================================================
do
    local CameraAimbotConfig = getgenv().Mooze["Camera Aimbot"]
    CameraAimbotConfig["Keybind"] = getgenv().Mooze["Global"]["Keybind"] or "C"
    local CurrentCamera = Services.Workspace.CurrentCamera
    local AimKey = Enum.KeyCode[CameraAimbotConfig["Keybind"]:upper()]

    local function IsKnockedOut(character)
        if not character then return false end
        local bodyEffects = character:FindFirstChild("BodyEffects")
        if bodyEffects then
            local ko = bodyEffects:FindFirstChild("K.O")
            if ko and ko.Value then return true end
        end
        local humanoid = character:FindFirstChildOfClass("Humanoid")
        if humanoid then
            local state = humanoid:GetState()
            if state == Enum.HumanoidStateType.Dead or
               state == Enum.HumanoidStateType.Physics or
               state == Enum.HumanoidStateType.Ragdoll then return true end
        end
        local rootPart = character:FindFirstChild("HumanoidRootPart")
        if rootPart and rootPart:FindFirstChild("GRABBING_CONSTRAINT") then return true end
        return false
    end

    local function GetLockTarget()
        if Locked and LockTarget then
            if LockTarget.Parent and LockTarget.Parent:FindFirstChild("Humanoid") then
                local humanoid = LockTarget.Parent:FindFirstChild("Humanoid")
                local character = LockTarget.Parent
                if humanoid and humanoid.Health > 0 and not IsKnockedOut(character) then
                    return LockTarget
                end
            end
            Locked = false; LockTarget = nil
            ShowNotification("Target Lost", "Target died or knocked - unlocked", 2)
            CameraAimbotConfig["Enabled"] = false
            return nil
        end
        return nil
    end

    local function FindMouseTarget()
        local bestTarget, shortestDistance = nil, math.huge
        local mousePosition = UserInputService:GetMouseLocation()
        for _, player in ipairs(Players:GetPlayers()) do
            if player ~= LocalPlayer and player.Character and not IsKnockedOut(player.Character) then
                local rootPart = player.Character:FindFirstChild("HumanoidRootPart")
                if rootPart then
                    local sp, on = CurrentCamera:WorldToViewportPoint(rootPart.Position)
                    if on and sp.Z > 0 then
                        local distance = (Vector2.new(sp.X, sp.Y) - mousePosition).Magnitude
                        if distance < shortestDistance then shortestDistance = distance; bestTarget = rootPart end
                    end
                end
            end
        end
        return bestTarget
    end

    UserInputService.InputBegan:Connect(function(input, processed)
        if processed then return end
        if input.KeyCode == AimKey then
            if not Locked then
                local bestTarget = FindMouseTarget()
                if bestTarget then
                    Locked = true; LockTarget = bestTarget
                    local player = Players:GetPlayerFromCharacter(bestTarget.Parent)
                    if player then ShowNotification("Locked On", player.Name, 3) end
                    CameraAimbotConfig["Enabled"] = true
                else
                    ShowNotification("No Target", "No valid player near mouse", 2)
                end
            else
                Locked = false; LockTarget = nil
                CameraAimbotConfig["Enabled"] = false
                ShowNotification("Unlocked", "Lock disabled", 2)
            end
        end
    end)

    RunService.RenderStepped:Connect(function()
        if CameraAimbotConfig["Enabled"] then
            local targetPart = GetLockTarget()
            if targetPart then
                CurrentCamera.CFrame = CFrame.new(CurrentCamera.CFrame.Position, targetPart.Position)
            end
        end
    end)
end

-- ============================================================================
-- SILENT AIMBOT
-- ============================================================================
do
    local SilentAimbotConfig = getgenv().Mooze["Silent Aimbot"]
    local Mouse = LocalPlayer:GetMouse()
    local LastMousePosition = Vector2.new(0, 0)
    local CurrentTarget = nil

    local function GetClosestPoint(player)
        local bestPart, bestDistance = nil, math.huge
        local pointScale = (SilentAimbotConfig["Closest Point"] or {})["Point Scale"] or 1.0
        if player.Character then
            for _, part in ipairs(GetBodyParts(player.Character)) do
                local sp, on = Camera:WorldToViewportPoint(part.Position)
                if on and sp.Z > 0 then
                    local d = (LastMousePosition - Vector2.new(sp.X, sp.Y)).Magnitude * pointScale
                    if d < bestDistance then bestPart, bestDistance = part, d end
                end
            end
        end
        return bestPart
    end

    local FOVCircle = Drawing.new("Circle")
    FOVCircle.Visible      = SilentAimbotConfig["FOV"]["Enabled"]
    FOVCircle.Transparency = 1
    FOVCircle.Thickness    = 2
    FOVCircle.Color        = Color3.new(1, 1, 1)
    FOVCircle.NumSides     = 100
    FOVCircle.Filled       = false

    local LastFOVUpdate = 0
    local FOVUpdateInterval = 0.033
    local CachedRadius = 0

    local function IsShiftLockActive()
        local playerGui = LocalPlayer:FindFirstChildOfClass("PlayerGui")
        if playerGui then
            local aimGui = playerGui:FindFirstChild("Aim")
            if aimGui and aimGui.Visible then return true end
        end
        local mouse = LocalPlayer:GetMouse()
        if mouse.Icon == "rbxasset://SystemCursors/Cross" then return true end
        local pm = LocalPlayer.PlayerScripts:FindFirstChild("PlayerModule")
        if pm then
            local cm = pm:FindFirstChild("CameraModule")
            if cm then
                local mlc = cm:FindFirstChild("MouseLockController")
                if mlc then
                    local iml = mlc:FindFirstChild("isMouseLocked")
                    if iml and iml.Value then return true end
                end
            end
        end
        return false
    end

    -- RenderStepped: only update position every frame for smooth tracking
    RunService.RenderStepped:Connect(function()
        if not SilentAimbotConfig["FOV"]["Enabled"] then
            FOVCircle.Visible = false
            return
        end
        FOVCircle.Visible = true
        if IsShiftLockActive() then
            FOVCircle.Position = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
            LastMousePosition  = FOVCircle.Position
        else
            local mp = UserInputService:GetMouseLocation()
            FOVCircle.Position = mp
            LastMousePosition  = mp
        end
    end)

    -- Heartbeat: throttled — update radius and find targets (heavier work)
    local function UpdateFOVLogic()
        local fovConfig  = SilentAimbotConfig["FOV"]
        local currentTool = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Tool")
        local radius = fovConfig["Size"].X * 5

        if fovConfig["Weapons Configuration"] and fovConfig["Weapons Configuration"]["Enabled"] and currentTool then
            local wn = string.lower(currentTool.Name or "")
            if string.find(wn, "shotgun") then
                radius = fovConfig["Weapons Configuration"]["Shotguns"].X * 5
            elseif string.find(wn, "pistol") then
                radius = fovConfig["Weapons Configuration"]["Pistols"].X * 5
            end
        end

        -- only write NumSides when radius actually changes
        if radius ~= CachedRadius then
            CachedRadius       = radius
            FOVCircle.Radius   = radius
            FOVCircle.NumSides = math.clamp(math.floor(radius * 2), 64, 128)
        end

        local bestPart, bestDistance = nil, math.huge
        for _, player in pairs(Players:GetPlayers()) do
            if player ~= LocalPlayer and player.Character then
                local targetPart = SilentAimbotConfig["Hit Part"] == "Closest Point"
                    and GetClosestPoint(player)
                    or player.Character:FindFirstChild("Head")
                if targetPart then
                    local sp, on = Camera:WorldToViewportPoint(targetPart.Position)
                    if on and sp.Z > 0 then
                        local d = (LastMousePosition - Vector2.new(sp.X, sp.Y)).Magnitude
                        if d < bestDistance and d <= radius then
                            bestPart, bestDistance = targetPart, d
                        end
                    end
                end
            end
        end
        CurrentTarget = bestPart
    end

    RunService.Heartbeat:Connect(function(deltaTime)
        LastFOVUpdate = LastFOVUpdate + deltaTime
        if LastFOVUpdate >= FOVUpdateInterval then
            LastFOVUpdate = 0
            UpdateFOVLogic()
        end
    end)

    local function ApplyPrediction(cframe, offset)
        return cframe * CFrame.new(offset.X, offset.Y, offset.Z)
    end

    if Capabilities[5] then
        local success = pcall(function()
            local metatable = getrawmetatable(game)
            setreadonly(metatable, false)
            local oldIndex = metatable.__index
            metatable.__index = newcclosure(function(object, property)
                if object:IsA("Mouse") and (property == "Hit" or property == "Target") then
                    local target = CurrentTarget
                    if target then
                        local prediction = SilentAimbotConfig["Prediction"]
                        local redirection = SilentAimbotConfig["Client Bullet Redirection"]
                        local currentTool = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Tool")
                        if redirection["Enabled"] and currentTool then
                            for _, weapon in ipairs(redirection["Weapons"]) do
                                if string.find(string.lower(tostring(currentTool.Name)), string.lower(weapon)) then
                                    prediction = redirection["Prediction"]; break
                                end
                            end
                        end
                        local offset = target.Velocity * Vector3.new(prediction.X, prediction.Y, prediction.Z)
                        if property == "Hit" then return ApplyPrediction(target.CFrame, offset)
                        else return target end
                    end
                end
                return oldIndex(object, property)
            end)
        end)
        if success then
            print("[Silent Aimbot] Metatable hooking enabled")
        else
            warn("[Silent Aimbot] Metatable hooking failed, using basic mode")
            ShowNotification("Silent Aimbot", "Running in basic mode", 5)
        end
    else
        warn("[Silent Aimbot] Metatable hooking not supported on this executor")
        ShowNotification("Silent Aimbot", "Limited mode (no metatable)", 5)
    end
end

