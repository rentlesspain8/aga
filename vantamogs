-- ============================================================================
-- SILENT AIM
-- ============================================================================
do
    local SilentAimbotConfig = getgenv().Mooze["Silent Aimbot"]
    local LocalPlayer        = Players.LocalPlayer
    local Camera             = Services.Workspace.CurrentCamera
    local Mouse              = LocalPlayer:GetMouse()
    local LastMousePosition  = Vector2.new(0, 0)
    local CurrentTarget      = nil

    local function GetClosestPoint(player)
        local bestPart, bestDistance = nil, math.huge
        local pointScale = SilentAimbotConfig["Closest Point"] and SilentAimbotConfig["Closest Point"]["Point Scale"] or 1.0
        if player.Character then
            local bodyParts = GetBodyParts(player.Character)
            for _, part in ipairs(bodyParts) do
                local screenPosition, onScreen = Camera:WorldToViewportPoint(part.Position)
                if onScreen and screenPosition.Z > 0 then
                    local pointPosition = Vector2.new(screenPosition.X, screenPosition.Y)
                    local distance = (LastMousePosition - pointPosition).Magnitude * pointScale
                    if distance < bestDistance then
                        bestPart, bestDistance = part, distance
                    end
                end
            end
        end
        return bestPart
    end

    local FOVCircle = Drawing.new("Circle")
    FOVCircle.Visible      = SilentAimbotConfig["FOV"]["Enabled"]
    FOVCircle.Transparency = 1
    FOVCircle.Thickness    = 2
    FOVCircle.Color        = Color3.new(1, 1, 1)
    FOVCircle.NumSides     = 100
    FOVCircle.Filled       = false

    local LastFOVUpdate    = 0
    local FOVUpdateInterval = 0.033

    local function IsShiftLockActive()
        if LocalPlayer.Character then
            local tool = LocalPlayer.Character:FindFirstChildOfClass("Tool")
            if tool and tool:FindFirstChild("Ammo") then return true end
        end
        local playerGui = LocalPlayer:FindFirstChildOfClass("PlayerGui")
        if playerGui then
            local aimGui = playerGui:FindFirstChild("Aim")
            if aimGui and aimGui.Visible then return true end
        end
        local mouse = LocalPlayer:GetMouse()
        if mouse.Icon == "rbxasset://SystemCursors/Cross" then return true end
        local playerModule = LocalPlayer.PlayerScripts:FindFirstChild("PlayerModule")
        if playerModule then
            local cameraModule = playerModule:FindFirstChild("CameraModule")
            if cameraModule then
                local mouseLockController = cameraModule:FindFirstChild("MouseLockController")
                if mouseLockController then
                    local isMouseLocked = mouseLockController:FindFirstChild("isMouseLocked")
                    if isMouseLocked and isMouseLocked.Value then return true end
                end
            end
        end
        return false
    end

    local function UpdateFOV()
        if IsShiftLockActive() then
            local centerScreen = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
            LastMousePosition = centerScreen
        else
            LastMousePosition = UserInputService:GetMouseLocation()
        end

        local fovConfig   = SilentAimbotConfig["FOV"]
        local currentTool = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Tool")
        local radius      = fovConfig["Size"].X * 5

        if fovConfig["Weapons Configuration"] and fovConfig["Weapons Configuration"]["Enabled"] and currentTool then
            local weaponName = string.lower(currentTool.Name or "")
            if string.find(weaponName, "shotgun") then
                radius = fovConfig["Weapons Configuration"]["Shotguns"].X * 5
            elseif string.find(weaponName, "pistol") then
                radius = fovConfig["Weapons Configuration"]["Pistols"].X * 5
            end
        end

        FOVCircle.Radius   = radius
        FOVCircle.NumSides = math.clamp(math.floor(radius * 2), 20, 100)
        FOVCircle.Position = LastMousePosition
        FOVCircle.Visible  = fovConfig["Enabled"]

        local bestPart, bestDistance = nil, math.huge
        for _, player in pairs(Players:GetPlayers()) do
            if player ~= LocalPlayer and player.Character then
                local targetPart = nil
                if SilentAimbotConfig["Hit Part"] == "Closest Point" then
                    targetPart = GetClosestPoint(player)
                else
                    targetPart = player.Character:FindFirstChild("Head")
                end
                if targetPart then
                    local screenPosition, onScreen = Camera:WorldToViewportPoint(targetPart.Position)
                    if onScreen and screenPosition.Z > 0 then
                        local pointPosition = Vector2.new(screenPosition.X, screenPosition.Y)
                        local distance = (LastMousePosition - pointPosition).Magnitude
                        if distance < bestDistance and distance <= radius then
                            bestPart, bestDistance = targetPart, distance
                        end
                    end
                end
            end
        end
        CurrentTarget = bestPart
    end

    -- FOV circle: RenderStepped for smooth position, Heartbeat throttled for target logic
    RunService.RenderStepped:Connect(function()
        local fovCfg = SilentAimbotConfig["FOV"]
        FOVCircle.Visible = fovCfg["Enabled"]
        if not FOVCircle.Visible then return end
        if IsShiftLockActive() then
            local c = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
            FOVCircle.Position = c
            LastMousePosition  = c
        else
            local mp = UserInputService:GetMouseLocation()
            FOVCircle.Position = mp
            LastMousePosition  = mp
        end
    end)

    RunService.Heartbeat:Connect(function(deltaTime)
        LastFOVUpdate = LastFOVUpdate + deltaTime
        if LastFOVUpdate >= FOVUpdateInterval then
            LastFOVUpdate = 0
            UpdateFOV()
        end
    end)

    local function ApplyPrediction(cframe, offset)
        return cframe * CFrame.new(offset.X, offset.Y, offset.Z)
    end

    -- Original metatable __index hook
    if Capabilities[5] then
        local success = pcall(function()
            local metatable = getrawmetatable(game)
            setreadonly(metatable, false)
            local oldIndex = metatable.__index
            metatable.__index = newcclosure(function(object, property)
                if object:IsA("Mouse") and (property == "Hit" or property == "Target") then
                    local target = CurrentTarget
                    if target then
                        local prediction = SilentAimbotConfig["Prediction"]
                        local redirection = SilentAimbotConfig["Client Bullet Redirection"]
                        local currentTool = (LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Tool")) or nil
                        if redirection["Enabled"] and currentTool then
                            local toolName = tostring(currentTool.Name)
                            for _, weapon in ipairs(redirection["Weapons"]) do
                                if string.find(string.lower(toolName), string.lower(weapon)) then
                                    prediction = redirection["Prediction"]
                                    break
                                end
                            end
                        end
                        local predictionMultiplier = Vector3.new(prediction.X, prediction.Y, prediction.Z)
                        local offset = target.Velocity * predictionMultiplier
                        if property == "Hit" then
                            return ApplyPrediction(target.CFrame, offset)
                        else
                            return target
                        end
                    end
                end
                return oldIndex(object, property)
            end)
        end)
        if success then
            print("[Silent Aimbot] Metatable hooking enabled with shiftlock fix")
        else
            warn("[Silent Aimbot] Metatable hooking failed, using basic mode")
            ShowNotification("Silent Aimbot", "Running in basic mode", 5)
        end
    else
        warn("[Silent Aimbot] Metatable hooking not supported on this executor")
        ShowNotification("Silent Aimbot", "Limited mode (no metatable)", 5)
    end

    -- __namecall hook: intercepts FireServer/InvokeServer and replaces
    -- any Vector3/CFrame arg that looks like a world position with the target pos.
    -- This is the single most impactful addition — makes the server register the hit.
    if Capabilities[5] then
        pcall(function()
            local mt          = getrawmetatable(game)
            local oldNamecall = mt.__namecall
            setreadonly(mt, false)
            mt.__namecall = newcclosure(function(self, ...)
                local method = getnamecallmethod()
                if not checkcaller()
                and (method == "FireServer" or method == "InvokeServer") then
                    local target = CurrentTarget
                    if target and target.Parent then
                        local pos   = target.CFrame.Position
                        local pred  = SilentAimbotConfig["Prediction"]
                        local offset = target.Velocity * Vector3.new(pred.X, pred.Y, pred.Z)
                        pos = pos + offset
                        local args = { ... }
                        for i, arg in ipairs(args) do
                            if typeof(arg) == "Vector3" then
                                local dist = (arg - Camera.CFrame.Position).Magnitude
                                if dist > 1 and dist < 5000 then
                                    args[i] = pos
                                end
                            elseif typeof(arg) == "CFrame" then
                                local dist = (arg.Position - Camera.CFrame.Position).Magnitude
                                if dist > 1 and dist < 5000 then
                                    local dir = (pos - Camera.CFrame.Position).Unit
                                    args[i] = CFrame.new(pos, pos + dir)
                                end
                            end
                        end
                        return oldNamecall(self, table.unpack(args))
                    end
                end
                return oldNamecall(self, ...)
            end)
            setreadonly(mt, true)
        end)
        print("[Silent Aimbot] __namecall hook active")
    end
end



-- SPREAD CHANGER  (only runs if shared.MoozeV2["Weapon Modifications"]["Spread Changer"]["Enabled"] == true)
-- ============================================================================
local function ApplySpread()
    local sc=CFG()["Weapon Modifications"]["Spread Changer"]
    if not sc["Enabled"] then return end
    local function norm(s) return tostring(s):lower():gsub("%W","") end
    for wk,ws in pairs(sc) do
        if wk~="Enabled" and type(ws)=="table" then
            local spread=0.1*(ws["Value"] or 1)
            local kn=norm(wk)
            for _,fn in ipairs(getgc(true)) do
                if type(fn)=="function" and islclosure(fn) and not isexecutorclosure(fn) then
                    local info=debug.getinfo(fn)
                    if info and info.short_src and norm(info.short_src):find(kn,1,true) then
                        for idx,c in ipairs(debug.getconstants(fn)) do
                            if type(c)=="number" and c>0 and c<0.3 then
                                debug.setconstant(fn,idx,spread)
                            end
                        end
                    end
                end
            end
        end
    end
end
ApplySpread()
LocalPlayer.CharacterAdded:Connect(function() task.wait(1); ApplySpread(); BodyPartCache={} end)

