        if not SpeedConfig["Enabled"] then return end
        if not Humanoid or Humanoid.Health <= 0 then return end
        local speed = SpeedConfig["Default"]["Value"]
        if Humanoid.Health < LowHealthThreshold then
            speed = SpeedConfig["Low Health"]["Value"]
        elseif Reloading then
            speed = SpeedConfig["Reloading"]["Value"]
        elseif Shooting then
            speed = SpeedConfig["Shooting"]["Value"]
        end
        if Humanoid.WalkSpeed ~= speed then Humanoid.WalkSpeed = speed end
    end)

    ShowNotification("Walkspeed", "speed: " .. SpeedConfig["Default"]["Value"], 3)
else
    print("[Walkspeed] Disabled by config")
end

